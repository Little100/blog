{
  "content.home.p0": {
    "en": "",
    "ja": "",
    "zh": "本博客支持丰富的 Markdown 扩展，包括自定义提示块、可折叠部分和锯齿形布局。探索以下功能以了解可能性。",
    "zh-TW": ""
  },
  "content.home.p1": {
    "en": "",
    "ja": "",
    "zh": "自定义块用交互式组件扩展标准 Markdown：可折叠面板、提示框、链接、评论，以及文字与图片交替的锯齿形布局。",
    "zh-TW": ""
  },
  "content.home.p10": {
    "en": "",
    "ja": "",
    "zh": "重要的警告或关键信息，读者不应忽略。",
    "zh-TW": ""
  },
  "content.home.p11": {
    "en": "",
    "ja": "",
    "zh": "---",
    "zh-TW": ""
  },
  "content.home.p12": {
    "en": "",
    "ja": "",
    "zh": "使用评论块在章节下方嵌入 Giscus 讨论串，为读者反应提供上下文。",
    "zh-TW": ""
  },
  "content.home.p13": {
    "en": "",
    "ja": "",
    "zh": "---",
    "zh-TW": ""
  },
  "content.home.p14": {
    "en": "",
    "ja": "",
    "zh": "链接块样式化外部引用，让读者可以轻松识别和导航到相关资源。",
    "zh-TW": ""
  },
  "content.home.p15": {
    "en": "",
    "ja": "",
    "zh": "这些只是几个例子。每个块都可以组合、嵌套和自定义以满足你的内容需求。",
    "zh-TW": ""
  },
  "content.home.p2": {
    "en": "",
    "ja": "",
    "zh": "图标 — 每种类型使用不同的图标：问号、电灯泡、感叹号、链接、评论。",
    "zh-TW": ""
  },
  "content.home.p3": {
    "en": "",
    "ja": "",
    "zh": "可折叠 — 某些提示框默认折叠，点击展开。",
    "zh-TW": ""
  },
  "content.home.p4": {
    "en": "",
    "ja": "",
    "zh": "自定义标题 — 可以覆盖默认的标题文本。",
    "zh-TW": ""
  },
  "content.home.p5": {
    "en": "",
    "ja": "",
    "zh": "---",
    "zh-TW": ""
  },
  "content.home.p6": {
    "en": "",
    "ja": "",
    "zh": "读者可能有的常见问题，在文章流程中直接回答。",
    "zh-TW": ""
  },
  "content.home.p7": {
    "en": "",
    "ja": "",
    "zh": "---",
    "zh-TW": ""
  },
  "content.home.p8": {
    "en": "",
    "ja": "",
    "zh": "补充主内容的有用提示、最佳实践或额外见解。",
    "zh-TW": ""
  },
  "content.home.p9": {
    "en": "",
    "ja": "",
    "zh": "---",
    "zh-TW": ""
