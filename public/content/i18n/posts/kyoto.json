  "post.kyoto.p0": {
    "en": "",
    "ja": "",
    "zh": "静默有颜色吗？在那条路上，灰石与朱红都显得同样安静。",
    "zh-TW": ""
  },
  "post.kyoto.p1": {
    "en": "",
    "ja": "",
    "zh": "石狐望着与人潮同一条路，却用着另一种时钟。",
    "zh-TW": ""
  },
  "post.kyoto.p3": {
